# Copy this file to .env and fill in your values.
# Then load it before running: source .env && python newsletter.py --email

# ── Gmail SMTP (required for --email) ─────────────────────────────────────────
# Use a Gmail App Password, NOT your regular password.
# How to create one:
#   1. Enable 2-Step Verification on your Google Account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create a new app password → copy the 16-character code below

export SMTP_USER="you@gmail.com"
export SMTP_PASS="xxxx xxxx xxxx xxxx"   # 16-char App Password

# Optional: send to a different address (defaults to SMTP_USER)
export TO_EMAIL="you@gmail.com"

# Optional: override SMTP server (defaults to Gmail)
# export SMTP_HOST="smtp.gmail.com"
# export SMTP_PORT="465"
